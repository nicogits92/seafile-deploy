# =============================================================================
# Caddyfile — Internal reverse proxy router
# =============================================================================
# Written by:  install-dependencies.sh (first install) / recover.sh (VM rebuild)
# Deployed to: /opt/seafile-caddy/Caddyfile on the Docker host
#
# This file is written before the stack is ever deployed because Caddy requires
# a valid config to start. If the file is missing at first deploy, Docker creates
# a directory at the bind-mount path instead, causing a crash-loop.
#
# Non-standard vs default Seafile Caddy config:
#   - Listens on :7080 (not :80) so Caddy sits behind NPM on the same host
#     without a port conflict. CADDY_PORT in .env controls this.
#   - Routes /sdoc-server/* and /socket.io/* to the seadoc container.
#     socket.io must be matched at root level (not under /sdoc-server/) or
#     SeaDoc shows "server disconnected" on every document open.
#   - Routes /notification/*, /metadata/*, /thumbnail-server/* to their
#     respective sidecar containers.
#   - Routes Collabora paths (/browser/*, /hosting/*, /cool/*, /lool/*) to
#     collabora:9980. WebSocket upgrades are handled natively by Caddy —
#     do NOT add Upgrade/Connection headers manually.
#   - All other requests fall through to the main seafile container.
# =============================================================================

:80 {

    # --- SeaDoc REST API ---
    handle_path /sdoc-server/* {
        reverse_proxy seadoc:80 {
            transport http {
                read_timeout 36000s
                write_timeout 36000s
            }
        }
    }

    # --- SeaDoc WebSocket ---
    # socket.io must be matched at root level — NOT under /sdoc-server/.
    # Without this block SeaDoc will show "server disconnected" on every document.
    handle /socket.io/* {
        reverse_proxy seadoc:80 {
            transport http {
                read_timeout 36000s
                write_timeout 36000s
            }
        }
    }

    # --- Notification Server ---
    handle_path /notification/* {
        reverse_proxy notification-server:8083
    }

    # --- Metadata Server ---
    handle_path /metadata/* {
        reverse_proxy metadata-server:8084
    }

    # --- Thumbnail Server ---
    handle_path /thumbnail-server/* {
        reverse_proxy thumbnail-server:80
    }

    # --- Collabora Online ---
    # Caddy handles WebSocket upgrades natively.
    # Do NOT manually add Upgrade/Connection headers — it will break the connection.
    handle /browser/* {
        reverse_proxy collabora:9980
    }

    handle /hosting/* {
        reverse_proxy collabora:9980
    }

    handle /cool/* {
        reverse_proxy collabora:9980 {
            transport http {
                read_timeout 36000s
                write_timeout 36000s
            }
        }
    }

    handle /lool/* {
        reverse_proxy collabora:9980 {
            transport http {
                read_timeout 36000s
                write_timeout 36000s
            }
        }
    }

    # --- Seafile Core (catch-all) ---
    handle {
        reverse_proxy seafile:80 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-Proto https
        }
    }
}
